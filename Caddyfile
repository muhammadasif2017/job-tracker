# Caddy auto-provisions Let's Encrypt TLS for the backend DuckDNS subdomain via the HTTP-01
# challenge (ports 80/443 must be reachable from the internet). The frontend is hosted on
# Vercel, so Caddy only fronts the backend API here. Domain comes from env.
{
	email {$ACME_EMAIL}
}

{$BACKEND_DOMAIN} {
	encode zstd gzip
	reverse_proxy backend:3001
}
