# Copy to `.env` on the server and fill in real values:  cp .env.deploy.example .env
# `.env` is gitignored — never commit real secrets.

# --- Database (Neon, managed free tier) ---
# From the Neon dashboard → Connection Details. Use the connection string and make sure
# it ends with ?sslmode=require. A single long-running server can use the direct
# (non-pooled) connection; switch to the pooled host only if you add serverless clients.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/job_tracker?sslmode=require

# --- Backend JWT secrets (min 32 chars each, different values) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_char_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_32_plus_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Backend DuckDNS hostname (NO protocol — used by Caddy for TLS) ---
BACKEND_DOMAIN=yourname-api.duckdns.org

# --- Frontend origin (WITH https://, NO trailing slash) ---
# The Vercel deployment URL. Used by the backend for CORS and the OAuth redirect.
# NEXT_PUBLIC_API_URL is NOT set here — it lives in the Vercel project settings
# (point it at https://yourname-api.duckdns.org, the backend domain above).
FRONTEND_URL=https://your-project.vercel.app

# --- Let's Encrypt contact email ---
ACME_EMAIL=you@example.com

# --- OAuth (optional; leave as placeholder to keep OAuth disabled) ---
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
