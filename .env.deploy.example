# Copy to `.env` on the server and fill in real values:  cp .env.deploy.example .env
# `.env` is gitignored — never commit real secrets.

# --- Postgres (self-hosted container) ---
POSTGRES_DB=job_tracker
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=replace_with_a_long_random_password

# --- Backend JWT secrets (min 32 chars each, different values) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_char_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_32_plus_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- DuckDNS hostnames (NO protocol — used by Caddy for TLS) ---
FRONTEND_DOMAIN=yourname.duckdns.org
BACKEND_DOMAIN=yourname-api.duckdns.org

# --- Public URLs (WITH https:// — used by the apps) ---
FRONTEND_URL=https://yourname.duckdns.org
NEXT_PUBLIC_API_URL=https://yourname-api.duckdns.org

# --- Let's Encrypt contact email ---
ACME_EMAIL=you@example.com

# --- OAuth (optional; leave as placeholder to keep OAuth disabled) ---
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
