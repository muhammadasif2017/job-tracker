generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  WISHLIST
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  GHOSTED
}

enum JobEventType {
  CREATED
  STATUS_CHANGE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  name         String
  avatarUrl    String?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  jobs         Job[]
  accounts     Account[]
}

model Account {
  id                String @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Job {
  id              String     @id @default(cuid())
  company         String
  position        String
  location        String?
  url             String?
  status          JobStatus  @default(APPLIED)
  notes           String?
  appliedAt       DateTime   @default(now())
  nextInterviewAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          JobEvent[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, appliedAt])
}

model JobEvent {
  id         String       @id @default(cuid())
  jobId      String
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type       JobEventType
  fromStatus JobStatus?
  toStatus   JobStatus
  note       String?
  createdAt  DateTime     @default(now())

  @@index([jobId])
  @@map("job_events")
}
