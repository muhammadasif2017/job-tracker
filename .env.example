# Copy this file to .env and fill in real values before running docker-compose.
# Generate secrets with: openssl rand -hex 32

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/job_tracker?schema=public

JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# Optional — app starts without these (OAuth will be disabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
